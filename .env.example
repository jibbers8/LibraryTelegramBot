TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_COMMAND_PASSWORD=
TELEGRAM_UNLOCK_MINUTES=60
TELEGRAM_POLL_INTERVAL=1.0

# Recommended for free VM reliability:
# Run Chrome in headed mode inside Xvfb.
BROWSER_HEADLESS=false
BROWSER_INTERACTIVE_MODE=false
BROWSER_KEEP_OPEN=false
BROWSER_CLOSE_EXISTING=false
ACCEPT_SIMILAR_TIMES=true
